{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm -w run typecheck:libs && pnpm --filter @workspace/chat-app run build",
  "outputDirectory": "artifacts/chat-app/dist",
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
